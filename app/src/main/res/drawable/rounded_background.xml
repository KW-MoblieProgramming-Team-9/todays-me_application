<!-- res/drawable/rounded_background.xml -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- 배경색 (연한 회색) -->
    <solid android:color="#D9D9D9" />

    <!-- 모서리 둥글게 -->
    <corners android:radius="20dp" />

    <!-- 안쪽 여백 (선택사항) -->
    <padding
        android:left="8dp"
        android:top="0dp"
        android:right="8dp"
        android:bottom="3dp" />

</shape>
