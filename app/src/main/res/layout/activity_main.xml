<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F3F4F6">


    <LinearLayout
        android:id="@+id/infoGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="96dp"
        android:paddingBottom="0dp">

        <TextView
            android:id="@+id/summaryTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="0dp"
            android:textColor="#AAAAAA"
            android:textSize="20sp" />

        <!-- ✅ 고정 말풍선 추가 -->
        <LinearLayout
            android:id="@+id/fixedChatBubble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/fixed_chat_bubble"
            android:orientation="horizontal"
            android:padding="12dp">

            <TextView
                android:id="@+id/fixedChatText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="오늘의 나."
                android:textColor="#000000"
                android:textSize="16sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- 날짜 헤더 컨테이너 (채팅 모드에서 표시) -->
    <LinearLayout
        android:id="@+id/dateHeaderContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone" />

    <ScrollView
        android:id="@+id/scrollview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/chatbot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

    <TextView
        android:id="@+id/previousRecordsButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="과거의 하루를 보러 가기."
        android:textColor="#000000"
        android:textSize="16sp"
        android:fontFamily="@font/paperlogy200"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="12dp"
        android:layout_gravity="center_horizontal"
        android:background="@android:color/transparent"
        android:textStyle="normal"
        android:clickable="true"
        android:focusable="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:background="@drawable/rounded_background"
        android:layout_marginBottom="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/inputMessage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:textColor="#000000"
            android:textColorHint="#666666"
            android:background="@android:color/transparent"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:textSize="16sp"/>

        <Button
            android:id="@+id/sendButton"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginEnd="4dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:backgroundTint="#1A73E8"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="@font/paperlogy500"
            android:textStyle="normal"
            android:text="전송"/>
    </LinearLayout>

</LinearLayout>
