<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#FAFAFA">

    <LinearLayout
        android:id="@+id/infoGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="0dp">

        <TextView
            android:id="@+id/summaryTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="0dp"
            android:textSize="17sp"
            android:textColor="#333333" />

        <!-- ✅ 고정 말풍선 추가 -->
        <LinearLayout
            android:id="@+id/fixedChatBubble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:orientation="horizontal"
            android:background="@drawable/fixed_chat_bubble">

            <TextView
                android:id="@+id/fixedChatText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="당신의 친구, 챗봇"
                android:textColor="#000000"
                android:textSize="16sp" />
        </LinearLayout>

    </LinearLayout>


    <ScrollView
        android:id="@+id/scrollview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/chatbot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>

    <TextView
        android:id="@+id/previousRecordsButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="과거의 하루를 보러가기."
        android:textColor="#3C3C3C"
        android:textSize="16sp"
        android:padding="8dp"
        android:layout_gravity="center"
        android:background="@android:color/transparent"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true" />
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_background"
        android:layout_marginBottom="6dp"
        android:layout_marginLeft="6dp"
        android:layout_marginRight="6dp"
        android:orientation="horizontal">
        
        <EditText
            android:id="@+id/inputMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"

            android:hint="메시지를 입력하세요"/>

        <Button
            android:id="@+id/sendButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#1A73E8"
            android:textColor="#000000"
            android:text="전송"/>
    </LinearLayout>

</LinearLayout>
